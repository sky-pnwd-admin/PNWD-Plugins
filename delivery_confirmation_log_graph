</head>
<body>
    <div class="container">
        <h1>📦 Inventory Stock Log</h1>
        
        <div id="authStatus" class="auth-status unauthenticated">
            Authenticating...
        </div>
        
        <form id="inventoryForm">
            <div class="form-group">
                <label for="movementType">Movement Type *</label>
                <select id="movementType" required>
                    <option value="IN">Stock In (Receiving)</option>
                    <option value="OUT">Stock Out (Usage/Transfer)</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="itemName">Item Name *</label>
                <input type="text" id="itemName" required placeholder="e.g., 5/8 Type X Drywall">
            </div>
            
            <div class="form-group">
                <label for="category">Category *</label>
                <select id="category" required>
                    <option value="">Select category...</option>
                    <option value="Drywall / Sheetrock">Drywall / Sheetrock</option>
                    <option value="Joint Compound / Mud">Joint Compound / Mud</option>
                    <option value="Screws / Fasteners">Screws / Fasteners</option>
                    <option value="Metal Framing">Metal Framing</option>
                    <option value="Insulation">Insulation</option>
                    <option value="Tape / Corner Bead">Tape / Corner Bead</option>
                    <option value="Tools">Tools</option>
                    <option value="Safety Equipment">Safety Equipment</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="quantity">Quantity *</label>
                <input type="number" id="quantity" required placeholder="e.g., 200">
            </div>
            
            <div class="form-group">
                <label for="unit">Unit *</label>
                <select id="unit" required>
                    <option value="">Select unit...</option>
                    <option value="Sheets">Sheets</option>
                    <option value="Boxes">Boxes</option>
                    <option value="Buckets">Buckets</option>
                    <option value="Rolls">Rolls</option>
                    <option value="Pieces">Pieces</option>
                    <option value="Bags">Bags</option>
                    <option value="Pallets">Pallets</option>
                    <option value="Linear Feet">Linear Feet</option>
                    <option value="Square Feet">Square Feet</option>
                    <option value="Each">Each</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="location">Storage Location *</label>
                <select id="location" required>
                    <option value="">Select location...</option>
                    <option value="Warehouse Storage">Warehouse Storage</option>
                    <option value="Bay 1">Bay 1</option>
                    <option value="Bay 2">Bay 2</option>
                    <option value="Bay 3">Bay 3</option>
                    <option value="Outdoor Yard">Outdoor Yard</option>
                    <option value="Tool Room">Tool Room</option>
                    <option value="Office Storage">Office Storage</option>
                    <option value="Truck - On Site">Truck - On Site</option>
                </select>
            </div>
            
            <div class="form-group">
                <label for="supplier">Supplier</label>
                <input type="text" id="supplier" placeholder="e.g., Pacific Coast Supply">
            </div>
            
            <div class="form-group">
                <label for="lowStockThreshold">Low Stock Alert Threshold</label>
                <input type="number" id="lowStockThreshold" placeholder="e.g., 50">
            </div>
            
            <div class="form-group">
                <label for="barcode">Barcode / SKU</label>
                <input type="text" id="barcode" placeholder="Optional barcode or SKU">
            </div>
            
            <div class="form-group">
                <label for="projectRef">Project Reference</label>
                <input type="text" id="projectRef" placeholder="e.g., Arhaus">
            </div>
            
            <div class="form-group">
                <label for="notes">Notes</label>
                <textarea id="notes" placeholder="Additional details..."></textarea>
            </div>
            
            <button type="submit" class="btn" id="submitBtn">Submit Inventory Log</button>
        </form>
        
        <div id="status" class="status"></div>
    </div>

    <script>
        // Configuration
        const msalConfig = {
            auth: {
                clientId: '7c3f7932-0ace-4b08-a3da-509d90be939f',
                authority: 'https://login.microsoftonline.com/ea96ba97-cbce-4c72-b769-94e03159166a',
                redirectUri: window.location.origin
            },
            cache: {
                cacheLocation: 'localStorage',
                storeAuthStateInCookie: false
            }
        };

        const loginRequest = {
            scopes: ['Files.ReadWrite.All', 'Sites.ReadWrite.All']
        };

        const siteId = 'pnwd.sharepoint.com,0c76eba1-3ee1-4b8b-bf31-672a6c59ba3f,e816da5b-53f0-44e4-9d60-98d0e513bf22';
        const operationsDriveId = 'b!oet2DOE-i0u_MWcqbFm6P1vaFujwU-REnWCY0OUTvyKnyCrpOAv9Toj_JjY7TCMy';
        const reportsDriveId = 'b!oet2DOE-i0u_MWcqbFm6P1vaFujwU-REnWCY0OUTvyLbOJ1KSkAYT7SN5A8cx6l4';

        const msalInstance = new msal.PublicClientApplication(msalConfig);
        let accessToken = null;

        // Initialize authentication
        async function initialize() {
            try {
                await msalInstance.initialize();
                const accounts = msalInstance.getAllAccounts();
                
                if (accounts.length > 0) {
                    msalInstance.setActiveAccount(accounts[0]);
                    await getToken();
                } else {
                    await login();
                }
            } catch (error) {
                console.error('Initialization error:', error);
                showStatus('Authentication failed. Please refresh the page.', 'error');
            }
        }

        async function login() {
            try {
                const response = await msalInstance.loginPopup(loginRequest);
                msalInstance.setActiveAccount(response.account);
                await getToken();
            } catch (error) {
                console.error('Login error:', error);
                showStatus('Login failed. Please try again.', 'error');
            }
        }

        async function getToken() {
            try {
                const account = msalInstance.getActiveAccount();
                if (!account) {
                    await login();
                    return;
                }

                const response = await msalInstance.acquireTokenSilent({
                    ...loginRequest,
                    account: account
                });
                
                accessToken = response.accessToken;
                updateAuthStatus(account.username);
            } catch (error) {
                if (error instanceof msal.InteractionRequiredAuthError) {
                    await msalInstance.acquireTokenPopup(loginRequest);
                } else {
                    console.error('Token acquisition error:', error);
                }
            }
        }

        function updateAuthStatus(username) {
            const authStatus = document.getElementById('authStatus');
            authStatus.className = 'auth-status authenticated';
            authStatus.textContent = \`✓ Authenticated as \${username}\`;
        }

        function showStatus(message, type) {
            const status = document.getElementById('status');
            status.textContent = message;
            status.className = \`status \${type}\`;
            
            if (type === 'success') {
                setTimeout(() => {
                    status.style.display = 'none';
                }, 5000);
            }
        }

        function generateRecordID() {
            const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
            let result = 'INV-';
            result += new Date().toISOString().slice(0,10).replace(/-/g, '');
            result += '-';
            for (let i = 0; i < 4; i++) {
                result += chars.charAt(Math.floor(Math.random() * chars.length));
            }
            return result;
        }

        async function writeToExcel(driveId, fileName, tableName, rowData) {
            const url = \`https://graph.microsoft.com/v1.0/drives/\${driveId}/root:/\${fileName}:/workbook/tables/\${tableName}/rows\`;
            
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Authorization': \`Bearer \${accessToken}\`,
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    values: [rowData]
                })
            });

            if (!response.ok) {
                const error = await response.text();
                throw new Error(\`Excel write failed: \${error}\`);
            }

            return await response.json();
        }

        document.getElementById('inventoryForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const submitBtn = document.getElementById('submitBtn');
            submitBtn.disabled = true;
            showStatus('Submitting inventory log...', 'loading');

            try {
                if (!accessToken) {
                    await getToken();
                }

                const recordID = generateRecordID();
                const timestamp = new Date().toISOString();
                const movementType = document.getElementById('movementType').value;
                const itemName = document.getElementById('itemName').value;
                const category = document.getElementById('category').value;
                const quantity = parseInt(document.getElementById('quantity').value);
                const unit = document.getElementById('unit').value;
                const location = document.getElementById('location').value;
                const supplier = document.getElementById('supplier').value;
                const lowStockThreshold = parseInt(document.getElementById('lowStockThreshold').value) || 0;
                const lowStockAlert = quantity <= lowStockThreshold ? 'TRUE' : 'FALSE';
                const barcode = document.getElementById('barcode').value;
                const projectRef = document.getElementById('projectRef').value;
                const notes = document.getElementById('notes').value;
                const submitter = msalInstance.getActiveAccount().username;

                // Inventory Log row (20 columns)
                const inventoryRow = [
                    recordID,                                    // Record_ID
                    timestamp,                                   // Timestamp
                    'InventoryStock',                           // Form_Type
                    'Operations',                                // Department
                    movementType,                                // Movement_Type
                    itemName,                                    // Item_Name
                    category,                                    // Category
                    quantity,                                    // Quantity
                    unit,                                        // Unit
                    location,                                    // Location
                    supplier,                                    // Supplier
                    lowStockThreshold,                           // Low_Stock_Threshold
                    lowStockAlert,                               // Low_Stock_Alert
                    barcode,                                     // Barcode
                    projectRef,                                  // Project_Ref
                    notes,                                       // Notes
                    submitter,                                   // Submitter
                    'Submitted',                                 // Status
                    'https://pnwd.sharepoint.com/sites/PNWD',   // SharePoint_Site
                    'OPS-002-Inventory/001-inventory_stock'     // SharePoint_Folder
                ];

                // Master Log row (18 columns)
                const masterLogRow = [
                    \`FORM-\${Date.now()}\`,                      // FormID
                    'InventoryStock',                           // FormType
                    timestamp,                                   // SubmissionDateTime
                    'Operations',                                // Department
                    submitter,                                   // SubmittedBy
                    submitter,                                   // SubmitterEmail
                    'Submitted',                                 // Status
                    projectRef || 'Inventory',                   // RelatedProject
                    '',                                          // OutputFileURL
                    '',                                          // OutputFileName
                    'Operations',                                // SharePointLibrary
                    'No',                                        // ApprovalRequired
                    '',                                          // ApprovedBy
                    '',                                          // ApprovalDateTime
                    '',                                          // Notes
                    timestamp,                                   // LastModified
                    recordID,                                    // PluginRecordID
                    \`\${movementType} — \${itemName} (\${quantity} \${unit}) @ \${location}\` // Summary
                ];

                // Write to Inventory Log
                await writeToExcel(
                    operationsDriveId,
                    'PNWD_Warehouse_Inventory.xlsx',
                    'InventoryLog',
                    inventoryRow
                );

                // Write to Master Log
                await writeToExcel(
                    reportsDriveId,
                    'PNWD_Master_Form_Log.xlsx',
                    'Form_Submissions_Log',
                    masterLogRow
                );

                showStatus('✓ Inventory log submitted successfully!', 'success');
                document.getElementById('inventoryForm').reset();

            } catch (error) {
                console.error('Submission error:', error);
                showStatus(\`Error: \${error.message}\`, 'error');
            } finally {
                submitBtn.disabled = false;
            }
        });

        // Initialize on load
        initialize();
    </script>
</body>
</html>`
})
